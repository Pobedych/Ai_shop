generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model items {
  id               String   @id(map: "pk_items") @db.Uuid
  name             String   @unique(map: "uq_items_name") @db.VarChar(100)
  description      String
  mini_description String?
  category         String   @db.VarChar(50)
  price            Decimal  @db.Decimal(10, 2)
  count            Int
  created_at       DateTime @db.Timestamptz(6)
  updated_at       DateTime @db.Timestamptz(6)

  @@index([category], map: "ix_items_category")
}

model users {
  id             String   @id(map: "pk_users") @db.Uuid
  tg_id          BigInt   @unique(map: "ix_users_tg_id")
  username       String?  @db.VarChar
  first_name     String?  @db.VarChar
  last_name      String?  @db.VarChar
  email          String?  @db.VarChar
  phone          String?  @db.VarChar
  is_active      Boolean  @default(true)
  role           String   @db.VarChar
  language       String   @db.VarChar
  balance        Decimal  @default(0.00) @db.Decimal(18, 2)
  purchase_count BigInt
  created_at     DateTime @db.Timestamp(6)
  updated_at     DateTime @db.Timestamp(6)
}
